{
  "host": "mikrotik",
  "title": "MikroTik",
  "fields": [
    {
      "label": "Uptime",
      "field": "uptime",
      "value_type": "integer",
      "format": "display_uptime"
    },
    {
      "label": "Free memory",
      "field": "free_memory",
      "value_type": "integer",
      "format": "display_memory"
    }
  ],
  "rules": [
    {
      "when": {
        "field": "update_available",
        "operator": "equals",
        "value": true
      },
      "then": {
        "method": "addNotification",
        "argument": "Software update available:\nVersion {{latest_version}}"
      }
    }
  ],
  "order": 10
}