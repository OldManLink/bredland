# ---------------------------------------------------------------------------
# Bredland example configuration
#
# Copy this file outside the repository (for example to
# /etc/bredland/secrets.env), replace the placeholder values, and keep the
# resulting file out of version control.
# ---------------------------------------------------------------------------
# The user to use for ssh on MikroTik.
#
# Deployment-specific.
MIKROTIK_SSH_USER=<replace-me>
# The hostname of MikroTik.
#
# Deployment-specific.
MIKROTIK_SSH_HOST=<replace-me>
# NOC heartbeat endpoint.
#
# Deployment-specific.
TELEMETRY_ENDPOINT=<replace-me>
# Authentication token for the NOC heartbeat endpoint.
#
# Deployment-specific.
MIKROTIK_NOC_TOKEN=<replace-me>
# Hostname for the MikroTik heartbeat client.
#
# Deployment-specific.
MIKROTIK_NOC_HOST=<replace-me>
# Time interval for the MikroTik heartbeat.
#
# Deployment-specific. Defaults to 5 minutes
MIKROTIK_HEARTBEAT_INTERVAL=5m
# Name of the heartbeat script on the MikroTik.
#
# Deployment-specific.
MIKROTIK_HEARTBEAT_SCRIPT_NAME=<replace-me>
# Name of the heartbeat script scheduler on the MikroTik.
#
# Deployment-specific.
MIKROTIK_HEARTBEAT_SCHEDULER_NAME=<replace-me>
# ---------------------------------------------------------------------------
# The SSH hostname of Bredland.
#
# Deployment-specific.
BREDLAND_SSH_HOST=<replace-me>
# Hostname for the Bredland heartbeat client.
#
# Deployment-specific.
BREDLAND_NOC_HOST=<replace-me>
# Schedule for the Bredland heartbeat.
#
# Deployment-specific. Defaults to 5 minutes
BREDLAND_HEARTBEAT_SCHEDULE=*:0/5
# Name of the heartbeat script on Bredland.
#
# Deployment-specific.
BREDLAND_HEARTBEAT_SCRIPT_FILE=<replace-me>
# Authentication token for the NOC heartbeat endpoint.
#
# Deployment-specific.
BREDLAND_NOC_TOKEN=<replace-me>
# ---------------------------------------------------------------------------
# The user to use for ssh on the NOC web hotel.
#
# Deployment-specific.
ODERLAND_SSH_USER=<replace-me>
# The hostname on the NOC web hotel.
#
# Deployment-specific.
ODERLAND_SSH_HOST=<replace-me>
# Location of the config file on the NOC web hotel.
#
# Deployment-specific.
TELEMETRY_CONFIG_FILE=<replace-me>
# Location of the endpoint file on the NOC web hotel.
#
# Deployment-specific.
TELEMETRY_ENDPOINT_FILE=<replace-me>
# Location of the telemetry output directory on the NOC web hotel.
#
# Deployment-specific.
NOC_DATA_DIR=<replace-me>
# Name of the log rotation script on the NOC web hotel.
#
# Deployment-specific.
NOC_ROTATE_SCRIPT_FILE=<replace-me>
