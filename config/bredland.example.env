# ---------------------------------------------------------------------------
# Bredland example configuration
#
# Copy this file outside the repository (for example to
# /etc/bredland/secrets.env), replace the placeholder values, and keep the
# resulting file out of version control.
# ---------------------------------------------------------------------------
# The user to use for ssh on MikroTik.
#
# Deployment-specific.
MIKROTIK_SSH_USER=<replace-me>
# The hostname of MikroTik.
#
# Deployment-specific.
MIKROTIK_SSH_HOST=<replace-me>
# NOC heartbeat endpoint.
#
# Deployment-specific.
MIKROTIK_NOC_ENDPOINT=<replace-me>
# Authentication token for the NOC heartbeat endpoint.
#
# Deployment-specific.
MIKROTIK_NOC_TOKEN=<replace-me>
# Hostname for the NOC heartbeat client.
#
# Deployment-specific.
MIKROTIK_NOC_HOST=<replace-me>
# Time interval for the NOC heartbeat.
#
# Deployment-specific. Defaults to 5 minutes
MIKROTIK_NOC_INTERVAL=5m
# Name of the heartbeat script on the NOC client.
#
# Deployment-specific.
MIKROTIK_NOC_SCRIPT_NAME=<replace-me>
# Name of the heartbeat script scheduler on the NOC client.
#
# Deployment-specific.
MIKROTIK_NOC_SCHEDULER_NAME=<replace-me>
# ---------------------------------------------------------------------------
# The user to use for ssh on the NOC web hotel.
#
# Deployment-specific.
ODERLAND_SSH_USER=<replace-me>
# The hostname on the NOC web hotel.
#
# Deployment-specific.
ODERLAND_SSH_HOST=<replace-me>
# Location of the config file on the NOC web hotel.
#
# Deployment-specific.
MIKROTIK_CONFIG_FILE=<replace-me>
# Location of the endpoint file on the NOC web hotel.
#
# Deployment-specific.
MIKROTIK_ENDPOINT_FILE=<replace-me>
# Location of the output directory on the NOC web hotel.
#
# Deployment-specific.
MIKROTIK_DATA_DIR=<replace-me>
